# Airflow Configuration
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_SECRET_KEY=your-secret-key-change-in-production

# MLflow Configuration
MLFLOW_DB_PASSWORD=mlflow

# Application Configuration
MLFLOW_TRACKING_URI=http://mlflow-server:5000
PYTHONUNBUFFERED=1

# FastAPI Serving
# Which registered MLflow model to serve. Tries Production first, falls back to Staging.
# Options: lightgbm_gbm (best performer), ridge_l2, ols_baseline, elastic_net
SERVING_MODEL_NAME=lightgbm_gbm
